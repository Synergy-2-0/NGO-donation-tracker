# Finance Module - Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/ngo-donation-tracker
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ngo-donation-tracker

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# PayHere Sandbox Configuration
PAYHERE_MERCHANT_ID=1226807
PAYHERE_MERCHANT_SECRET=your-merchant-secret-here
PAYHERE_MODE=sandbox
# For production, change to: PAYHERE_MODE=production

# PayHere URLs
PAYHERE_RETURN_URL=http://localhost:3000/payment/success
PAYHERE_CANCEL_URL=http://localhost:3000/payment/cancel
PAYHERE_NOTIFY_URL=http://localhost:3000/api/finance/payhere/callback

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug

# CLOUDINARY Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Brevo email API (used for partner/agreement notifications)
BREVO_API_KEY=your_brevo_api_key

# SMTP fallback for donor emails
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# Free geocoding provider base URL (Nominatim)
GEOCODING_PROVIDER=nominatim
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org