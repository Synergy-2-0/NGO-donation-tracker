# Finance Module - Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/ngo-donation-tracker
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ngo-donation-tracker

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# PayHere Sandbox Configuration
PAYHERE_MERCHANT_ID=1226807
PAYHERE_MERCHANT_SECRET=your-merchant-secret-here
PAYHERE_MODE=sandbox
# For production, change to: PAYHERE_MODE=production

# PayHere URLs
PAYHERE_RETURN_URL=http://localhost:3000/payment/success
PAYHERE_CANCEL_URL=http://localhost:3000/payment/cancel
PAYHERE_NOTIFY_URL=http://localhost:3000/api/finance/payhere/callback

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=debug
